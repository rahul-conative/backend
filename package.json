{
  "name": "ecommerce-backend",
  "version": "1.0.0",
  "description": "Production-grade modular monolith e-commerce backend ready for future microservice extraction.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "node --check src/server.js",
    "db:migrate": "node scripts/db/run-sequelize-migrations.js",
    "db:migrate:undo": "node scripts/db/rollback-sequelize-migration.js",
    "db:seed": "node scripts/db/seed-dev-data.js",
    "db:seed:cms-static": "node scripts/db/seed-cms-static-content.js",
    "db:seed:catalog-media": "node scripts/db/seed-catalog-media.js",
    "db:seed:platform": "node scripts/db/seed-platform-metadata.js",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:reset:all": "node scripts/db/reset-all-databases.js",
    "db:create-super-admin": "node scripts/db/create-super-admin.js",
    "db:seed:rbac": "node scripts/db/seed-rbac.js",
    "postman:sync": "node scripts/postman/sync-postman-collection.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.15.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.16.0",
    "cloudinary": "^2.3.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^12.7.0",
    "google-auth-library": "^9.14.2",
    "handlebars": "^4.7.8",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.2.9",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "objection": "^3.1.5",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "razorpay": "^2.9.6",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.2",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.8.0",
    "nodemon": "^3.1.4",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.3.3"
  }
}
